# ============================================================
# DRISHTI VEDIC+ v2.0 — Environment Variables
# Copy to .env.local and fill in.
# WITHOUT any keys set, the app runs in full MOCK MODE
# (numerology is 100% real math; astrology + narration use mocks).
# ============================================================

# ---- Prokerala (astrology) — sign up at https://api.prokerala.com ----
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# ---- Google Gemini (narration) — https://aistudio.google.com/app/apikey ----
GEMINI_API_KEY=

# ---- Supabase (auth + DB) — https://supabase.com/dashboard ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Razorpay (billing) — https://dashboard.razorpay.com ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
